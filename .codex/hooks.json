{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/session-start-context.mjs\" codex",
            "statusMessage": "Loading repository conventions"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/post-tool-use-quality.mjs\"",
            "statusMessage": "Running Biome and Oxlint on changed files",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
