{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "screenshots/**"],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  }
}
