{
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!dist", "!node_modules", "!.codex", "!.codex/**", "!screenshots/*.png"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space",
      "indentWidth": 2
    }
  }
}
