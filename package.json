{
  "name": "agent-ts-workflow",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-neutral TypeScript starter with Oxlint, Biome, shared hooks, and ExecPlan workflow.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:staged": "lint-staged --concurrent false",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "prepare": "husky",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "hook:posttooluse": "node ./scripts/agent-hooks/post-tool-use-quality.mjs",
    "setup:bootstrap": "./scripts/setup-agent-tooling.sh bootstrap",
    "setup:bootstrap:full": "./scripts/setup-agent-tooling.sh bootstrap --with-deps",
    "setup:codex": "./scripts/setup-agent-tooling.sh setup codex",
    "setup:claude": "./scripts/setup-agent-tooling.sh setup claude"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysj101/agent-ts-workflow.git"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/ysj101/agent-ts-workflow/issues"
  },
  "homepage": "https://github.com/ysj101/agent-ts-workflow#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  }
}
