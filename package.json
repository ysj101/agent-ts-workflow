{
  "name": "codex-ts-workflow",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-first TypeScript starter with Oxlint, Biome, hooks, and ExecPlan workflow.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "quality": "pnpm run format && pnpm run lint && pnpm run typecheck",
    "hook:posttooluse": "node ./.codex/hooks/post-tool-use-quality.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysj-101/codex-ts-workflow.git"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/ysj-101/codex-ts-workflow/issues"
  },
  "homepage": "https://github.com/ysj-101/codex-ts-workflow#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  }
}
